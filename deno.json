{
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["deno.ns", "dom", "dom.iterable", "dom.asynciterable", "esnext"]
  },
  "tasks": {
    "test": "deno test src/engine/",
    "check": "deno fmt --check src/engine/ && deno lint src/engine/ && deno check src/engine/*.ts"
  },
  "fmt": {
    "include": ["src/engine/"]
  },
  "lint": {
    "include": ["src/engine/"]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19"
  }
}
